# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=/run/secrets/firebase-service-account.json

# InsightFace
INSIGHTFACE_MODEL=buffalo_l
MATCH_THRESHOLD=0.65
LIVENESS_REQUIRED=true

# Camera
CAMERA_INDEX=0          # 0 = default webcam; or RTSP URL for IP camera
CAMERA_FPS=15

# API
API_HOST=0.0.0.0
API_PORT=8000

# Data Retention
ATTENDANCE_RETENTION_DAYS=1095   # 3 years

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Timezone
TIMEZONE=Asia/Kolkata

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=
SENDER_NAME=Face Attendance System