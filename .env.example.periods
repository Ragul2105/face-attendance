# IMPORTANT: Add these environment variables to your .env file

# Email Configuration (for absence notifications)
# Using Gmail example - for production, use dedicated email service
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password  # For Gmail, use App Password, not regular password
SENDER_NAME="Face Attendance System"
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Optional: If using different email provider, adjust accordingly
# For Office 365: SMTP_SERVER=smtp.office365.com, SMTP_PORT=587
# For AWS SES: SMTP_SERVER=email-smtp.region.amazonaws.com, SMTP_PORT=587

# Timezone (already set to IST by default, but can be customized)
TIMEZONE=Asia/Kolkata  # IST = UTC+5:30
